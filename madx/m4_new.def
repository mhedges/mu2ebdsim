!Original AC929A+B (3+3 m new type) temporarily replaced by 6 K04 (6*1.0414 m)                                                              
!to get kickers in the ces0                                                                                                                 
!                                                                                                                                           
!CDA correctors (with coils+connections) are 1.5875 m long                                                                                  
!therefore one should keep free at least (1.5875-1.2192)/2 = 0.18415 at                                                                     
!each end. For this it would be good to shift PCOL by +0.1 or 0.2 m                                                                         
!Same for VDPA where the free spaces must be (1.0668-0.762)/2 = 0.1524 m                                                                    
!                                                                                                                                           
!VDPA have been suppressed!                                                                                                                 
!Some Trim type changed according to Jim mail (May 13 2015)                                                                                 . 
!Add collimator after Q907 (Eric mail from May 15 2015)                                                                                     
!Q925 from L=0.2286 to L=0.41402                                                                                                            
!Q926 from L=0.2286 to L=0.32004                                                                                                            
!Now Q925 and Q926 back to 0.2286                                                                                                           
                                                                                                                                            
                                                                                                                                           
MSTART        : MARKER ;                                                                                                   
!g-2                                                                                                                                        
v901_angle=0.11341001;!g-2                                                                                                                  
                                                                                                                                            
                                                                                                                                            
IC: instrument, L=0.15875;!6.25"                                                                                                            
PWC:  instrument, L=0.15875;!6.25"                                                                                                          
ecmag_tilt:=pi/2+0.01023631;!restore tilt
ecmag_ANGLE=-.05720001;                                                                                                                     
ECMAG_srot =-0.0000496625;
rho_ECMAG:=l_ecmag*0.5/(sin(ecmag_angle*0.5));
ECMAG_arc:= rho_ECMAG*ecmag_angle;
ds_ECMAG:= ECMAG_arc*0.5 ;!half arc length                                                                                                                             
ECMAG         : RBEND, L:= l_ecmag, ANGLE:=ecmag_angle, K1=  0.00000000, K2=  0.00000000, TILT:= ecmag_tilt ;
value, l_ecmag;
